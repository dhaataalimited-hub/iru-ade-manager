# Apple signing & notarization credentials
# Copy to .env and fill in your own values, then: set -a; source .env; set +a

APPLE_ID="your@apple.id"
APPLE_TEAM_ID="XXXXXXXXXX"
APPLE_SIGNING_IDENTITY="Developer ID Application: <Your Name> (XXXXXXXXXX)"

# App-specific password from https://appleid.apple.com (format: xxxx-xxxx-xxxx-xxxx — 4 groups)
# NB: Tauri bundler reads APPLE_PASSWORD (not APPLE_ID_PASSWORD); both set for tooling compatibility.
APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"
APPLE_ID_PASSWORD="xxxx-xxxx-xxxx-xxxx"
